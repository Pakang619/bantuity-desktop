{
  "name": "bantuity-desktop",
  "version": "1.2.7",
  "description": "Bantuity desktop — Plotex, Copilot, and local Stata in one app",
  "main": "electron/main.js",
  "author": "Bantuity",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "icons": "node ./scripts/generate-icons.mjs",
    "bundle:web": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/bundle-web.ps1",
    "pack": "npm run icons && electron-builder --dir",
    "dist": "npm run icons && npm run bundle:web && electron-builder --win nsis",
    "dist:portable": "npm run icons && npm run bundle:web && electron-builder --win portable",
    "dist:quick": "npm run icons && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.bantuity.desktop",
    "productName": "Bantuity",
    "executableName": "Bantuity",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "icon": "icon.ico",
    "afterPack": "./scripts/afterPack.cjs",
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "apps",
        "to": "apps",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/connector",
        "to": "connector",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Bantuity-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bantuity",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.2",
    "rcedit": "^5.0.2",
    "sharp": "^0.35.3"
  }
}
